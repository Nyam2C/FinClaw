# Discord (required)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Anthropic Claude (required)
ANTHROPIC_API_KEY=

# Finance APIs (optional — enables market tools when set)
ALPHA_VANTAGE_KEY=
COINGECKO_API_KEY=

# Gateway auth (optional — API key for TUI/Web clients)
FINCLAW_API_KEY=
GATEWAY_JWT_SECRET=

# Storage (optional)
# Local default: ~/.finclaw/db.sqlite
# Docker default (via compose): /data/db.sqlite
FINCLAW_DB_PATH=
