# Discord (required)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Anthropic Claude (required)
ANTHROPIC_API_KEY=

# Finance APIs (optional — enables market tools when set)
# Alpha Vantage 단일 키로 주가·뉴스 둘 다 커버 (무료 tier: 분당 5회)
ALPHA_VANTAGE_KEY=
COINGECKO_API_KEY=

# Embedding (optional — enables hybrid RAG; without it, FTS-only fallback)
# Get from https://www.voyageai.com/ (free tier: 200M tokens)
# Alternative: OPENAI_API_KEY for text-embedding-3-small
VOYAGE_API_KEY=

# Gateway auth (optional — API key for TUI/Web clients)
FINCLAW_API_KEY=
GATEWAY_JWT_SECRET=

# Storage (optional)
# Local default: ~/.finclaw/db.sqlite
# Docker default (via compose): /data/db.sqlite
FINCLAW_DB_PATH=
